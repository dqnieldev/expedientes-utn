datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(ALUMNO)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  ALUMNO
}