datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(ALUMNO)
  createdAt DateTime @default(now())

  mustChangePassword Boolean @default(true)

  resetToken          String?
  resetTokenExpiry    DateTime?

  alumno    Alumno?

  @@index([role])          // filtrar admins vs alumnos
}

model Alumno {
  id                    Int      @id @default(autoincrement())
  nombre                String
  matricula             String   @unique
  carrera               String
  cuatrimestre_actual   Int
  estado                String   @default("ACTIVO")
  documentos            Documento[]
  foto                  String?

  @@index([estado])        // filtrar por ACTIVO/BAJA/BAJA_TEMPORAL
  @@index([carrera])       // filtrar por carrera
  @@index([createdAt])     // ordenar por fecha

  // DATOS PERSONALES
curp                    String?
fecha_nacimiento        DateTime?
lugar_nacimiento        String?
sexo                    String?
estado_civil            String?

//DIRECCION
  calle                  String?
  numero                 String?
  colonia                String?
  codigo_postal          String?
  telefono               String?
  ciudad                 String?
  estado_direccion       String?
  
  usuarioId             Int      @unique
  usuario               Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt             DateTime @default(now())
}

model Documento {
  id        Int      @id @default(autoincrement())
  tipo      String
  url       String
  estado    EstadoDocumento @default(EN_REVISION)
  alumnoId  Int
  alumno    Alumno  @relation(fields: [alumnoId], references: [id])
  createdAt DateTime @default(now())
  razonRechazo String?

  @@unique([alumnoId, tipo])

  @@index([estado])        // filtrar por APROBADO/RECHAZADO/EN_REVISION
  @@index([alumnoId])      // buscar docs de un alumno (ya existe el unique pero este ayuda en queries)
  @@index([createdAt])     // ordenar por fecha
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  accion    String   // APROBAR_DOCUMENTO, RECHAZAR_DOCUMENTO, CAMBIAR_ESTADO, etc.
  entidad   String   // DOCUMENTO, ALUMNO, BACKUP, AUTH
  entidadId Int?     // ID del recurso afectado
  detalle   String?  // descripción legible
  usuarioId Int?     // quien ejecutó la acción
  ip        String?  // IP del request
  createdAt DateTime @default(now())

  @@index([accion])
  @@index([usuarioId])
  @@index([createdAt])
}

enum EstadoDocumento {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum Role {
  ADMIN
  ALUMNO
}